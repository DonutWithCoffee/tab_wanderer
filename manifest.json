{
  "manifest_version": 3,
  "name": "tab_wanderer",
  "version": "0.9.9",
  "permissions": [
    "tabs",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://amperkot.ru/*",
    "https://seller.ozon.ru/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://amperkot.ru/admin/orders*",
        "https://amperkot.ru/web-apps/wh3/*"
      ],
      "js": [
        "core/warehouse-barcode-extractor.js",
        "core/warehouse-ozon-view-model.js",
        "content.js"
      ]
    },
    {
      "matches": [
        "https://seller.ozon.ru/app/products*"
      ],
      "js": [
        "core/ozon-product-search.js",
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "warehouse-barcode-bridge.js"
      ],
      "matches": [
        "https://amperkot.ru/*"
      ]
    },
    {
      "resources": [
        "ozon-product-bridge.js"
      ],
      "matches": [
        "https://seller.ozon.ru/*"
      ]
    }
  ]
}
