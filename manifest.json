{
  "manifest_version": 3,
  "name": "tab_wanderer",
  "description": "Локальный мониторинг заказов Amperkot admin с уведомлениями, отслеживаемыми заказами и складским Ozon-модулем.",
  "version": "1.0.4",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://amperkot.ru/*",
    "https://seller.ozon.ru/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://amperkot.ru/admin/orders*",
        "https://amperkot.ru/web-apps/wh3/*"
      ],
      "js": [
        "core/warehouse-barcode-extractor.js",
        "core/warehouse-ozon-view-model.js",
        "content.js"
      ]
    },
    {
      "matches": [
        "https://seller.ozon.ru/app/products*"
      ],
      "js": [
        "core/ozon-product-search.js",
        "ozon-product-bridge.js",
        "content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "warehouse-barcode-bridge.js"
      ],
      "matches": [
        "https://amperkot.ru/*"
      ],
      "use_dynamic_url": true
    },
    {
      "resources": [
        "ozon-product-page-bridge.js"
      ],
      "matches": [
        "https://seller.ozon.ru/*"
      ],
      "use_dynamic_url": true
    }
  ]
}
